{
  "module": "cli-timeline-ops",
  "version": "v0.1",
  "description": "Timeline mutation CLI surface. All subcommands operate on timeline.json only — no rendering.",
  "crud": {
    "new": {"cmd": "nextframe new <path> [--duration N] [--fps N] [--width N] [--height N]"},
    "add-clip": {"cmd": "nextframe add-clip <path> --track ID --scene ID --start <num|json> --duration N [--params k=v ...]"},
    "move-clip": {"cmd": "nextframe move-clip <path> <clip-id> --to N"},
    "resize-clip": {"cmd": "nextframe resize-clip <path> <clip-id> --duration N"},
    "remove-clip": {"cmd": "nextframe remove-clip <path> <clip-id>"},
    "set-param": {"cmd": "nextframe set-param <path> <clip-id> --<key> <value>"},
    "add-marker": {"cmd": "nextframe add-marker <path> --id ID --at N [--label TEXT]"},
    "list-clips": {"cmd": "nextframe list-clips <path> [--json]"},
    "dup-clip": {"cmd": "nextframe dup-clip <path> <clip-id> --to N"}
  },
  "simulate": {
    "scenarios": [
      {
        "id": "sim-build-12s",
        "name": "AI builds the 12s product launch opening from 06-ai-loop.md",
        "steps": [
          "nextframe new /tmp/demo.json --duration 12",
          "nextframe add-marker /tmp/demo.json --id chapter-intro --at 0",
          "nextframe add-marker /tmp/demo.json --id chapter-hook --at 4",
          "nextframe add-marker /tmp/demo.json --id chapter-reveal --at 8",
          "nextframe add-clip /tmp/demo.json --track v1 --scene auroraGradient --start 0 --duration 12",
          "nextframe add-clip /tmp/demo.json --track v3 --scene kineticHeadline --start '{at:\"chapter-hook\"}' --duration 4 --params text='NEXTFRAME'",
          "nextframe add-clip /tmp/demo.json --track v3 --scene glitchText --start '{at:\"chapter-reveal\"}' --duration 3 --params text='AI-NATIVE'",
          "nextframe add-clip /tmp/demo.json --track v4 --scene lowerThirdVelvet --start '{after:\"clip-glitchText-1\", gap: 0.5}' --duration 2",
          "nextframe validate /tmp/demo.json",
          "nextframe gantt /tmp/demo.json",
          "nextframe render /tmp/demo.json /tmp/demo.mp4"
        ]
      },
      {
        "id": "sim-human-adjust",
        "name": "Human tweaks clip durations",
        "steps": [
          "nextframe list-clips /tmp/demo.json",
          "nextframe resize-clip /tmp/demo.json clip-kineticHeadline-1 --duration 5",
          "nextframe move-clip /tmp/demo.json clip-glitchText-1 --to 9.0",
          "nextframe validate /tmp/demo.json",
          "nextframe render /tmp/demo.json /tmp/demo2.mp4"
        ]
      }
    ]
  }
}
