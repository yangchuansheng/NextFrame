{
  "module": "scene-contract",
  "version": "v0.1",
  "description": "Design notes for scene extension points.",
  "registry_shape": {
    "entry": "{ id, render, describe, META }",
    "meta_required": ["id", "category", "description", "duration_hint", "params"],
    "param_required": ["name", "type", "default"]
  },
  "forbidden_tokens": ["Math.random(", "Date.now(", "performance.now(", "new Image()", "fetch(", "top-level let", "top-level new Map"],
  "extension_rule": "Add a file plus one registry edit; importing src/scenes/index.js must validate everything."
}
