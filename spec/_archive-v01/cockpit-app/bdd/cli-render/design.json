{
  "module": "cli-render",
  "version": "v0.1",
  "description": "Design spec for the render-family CLI commands. Focus: terminal UX + data shapes. No DOM/CSS.",
  "output_shapes": {
    "success": {
      "ok": true,
      "_fields": "depend on subcommand; always includes 'ok: true'"
    },
    "error": {
      "ok": false,
      "error": "human-readable error string",
      "hints": ["actionable hint 1", "actionable hint 2"],
      "gate": "which safety gate failed (for validation errors)"
    }
  },
  "exit_codes": {
    "0": "ok: true",
    "1": "ok: false (any kind of failure)",
    "2": "internal error (unexpected throw, should never happen)"
  },
  "stream_semantics": {
    "stdout": "JSON result only (pipe-safe)",
    "stderr": "progress + diagnostics (line-prefixed with [nextframe] tag)"
  },
  "verbose_format": {
    "progress_line": "[nextframe] render progress frame=120/360 t=4.0 elapsed=1450ms eta=2900ms",
    "done_line": "[nextframe] render done frame=360 elapsed=4350ms"
  },
  "gantt_visual": {
    "width_default": 80,
    "row_height": 1,
    "example": "v1 |████████████████████████████████████████████████| aurora (0:00-0:12)\nv2 |                ████████░░░░                          | kinetic (0:04-0:08)\nv3 |                    ████                              | glitch (0:05-0:07)\n   |0:00        0:03        0:06        0:09        0:12|",
    "marker_char": "▼",
    "chapter_line": "separator line between chapters"
  },
  "ascii_visual": {
    "width_default": 60,
    "height_default": 30,
    "char_ramp": " .:-=+*#%@",
    "color_policy": "luminance only (rgb→grayscale→char)"
  },
  "describe_output_schema": {
    "t": "number (absolute seconds)",
    "visible_clips": [
      {
        "id": "string (clip id)",
        "scene": "string (scene id)",
        "track": "string (track id)",
        "local_t": "number (time within clip)",
        "bbox": {"x": "number 0-1", "y": "number 0-1", "w": "number 0-1", "h": "number 0-1"},
        "content": "object (scene-specific; text content, colors, phase)",
        "z": "number (z-order, 0 = bottom)"
      }
    ]
  }
}
