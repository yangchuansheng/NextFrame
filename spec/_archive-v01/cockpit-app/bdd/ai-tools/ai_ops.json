{
  "module": "ai-tools",
  "version": "v0.1",
  "description": "Machine-facing tool registry.",
  "crud": {
    "list_scenes": {"cmd": "TOOLS.list_scenes.handler({})"},
    "get_scene_meta": {"cmd": "TOOLS.get_scene_meta.handler({id})"},
    "validate_timeline": {"cmd": "TOOLS.validate_timeline.handler({timeline})"},
    "resolve_time": {"cmd": "TOOLS.resolve_time.handler({timeline, expr})"},
    "describe_frame": {"cmd": "TOOLS.describe_frame.handler({timeline, t})"},
