{
  "module": "scene-contract",
  "version": "v0.1",
  "stories": [
    {
      "id": "verify-scene-contract-1",
      "ref": "scene-contract-2",
      "name": "broken registry entry fails fast",
      "steps": [
        {"op": "run", "cmd": "node -e 'import(\"./nextframe-cli/src/scenes/_contract.js\").then(m=>m.assertSceneContract(\"x\", {}))'"},
        {"op": "assert_stderr_contains", "value": "SceneContractError"}
      ]
    },
    {
      "id": "verify-scene-contract-2",
      "ref": "scene-contract-5",
      "name": "new scene is auto-discovered",
      "steps": [
        {"op": "run", "cmd": "node nextframe-cli/bin/nextframe.js scenes --json", "capture": "stdout"},
        {"op": "assert_contains", "path": "stdout", "value": "\"vignette\""}
      ]
    }
  ]
}
