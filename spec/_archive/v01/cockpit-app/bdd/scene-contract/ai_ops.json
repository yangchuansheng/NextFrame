{
  "module": "scene-contract",
  "version": "v0.1",
  "description": "AI operations for extending the scene registry safely.",
  "crud": {
    "add-scene-file": {"cmd": "create src/scenes/<id>.js exporting function <id>(t, params, ctx, globalT)"},
    "wire-registry": {"cmd": "edit src/scenes/index.js import + META_TABLE + RENDER_FNS"},
    "run-contract-tests": {"cmd": "node --test test/scene-contract.test.js && node --test test/architecture.test.js"}
  },
  "simulate": {
    "scenarios": [
      {
        "id": "sim-scene-add",
        "name": "add vignette-style overlay",
        "steps": [
          "Create src/scenes/vignette.js",
          "Add import and META entry in src/scenes/index.js",
          "Run node --test test/scene-contract.test.js",
          "Run node bin/nextframe.js scenes --json"
        ],
        "assert": ["vignette appears in registry output", "scene-contract tests stay green"]
      }
    ]
  }
}
