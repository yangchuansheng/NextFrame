{
  "module": "cli-render",
  "version": "v0.1",
  "description": "Two-layer CLI interface: crud (daily ops) + simulate (validator that acts like a human running commands).",
  "crud": {
    "render": {
      "cmd": "nextframe render <timeline.json> <out.mp4>",
      "flags": ["--verbose", "--fps=30", "--json"],
      "returns": "{ok, output, frames, duration, elapsed_ms}"
    },
    "frame": {
      "cmd": "nextframe frame <timeline.json> <t> <out.png>",
      "flags": ["--json"],
      "returns": "{ok, output, t, elapsed_ms}"
    },
    "validate": {
      "cmd": "nextframe validate <timeline.json>",
      "flags": ["--json"],
      "returns": "{ok, errors?: [{gate, msg, hint}]}"
    },
    "describe": {
      "cmd": "nextframe describe <timeline.json> <t>",
      "flags": ["--json"],
      "returns": "{t, visible_clips: [{id, scene, bbox, content, ...}]}"
    },
    "gantt": {
      "cmd": "nextframe gantt <timeline.json>",
      "flags": ["--width=80"],
      "returns": "stdout: ASCII gantt chart"
    },
    "ascii": {
      "cmd": "nextframe ascii <timeline.json> <t>",
      "flags": ["--width=60"],
      "returns": "stdout: ASCII art of frame"
    }
  },
  "simulate": {
    "describe": "Scripted scenarios that replicate how AI/human uses the CLI to build up a timeline and verify the result.",
    "scenarios": [
      {
        "id": "sim-1",
        "name": "end-to-end: new → add → render → probe",
        "steps": [
          "nextframe new /tmp/t.json --duration 12 --fps 30",
          "nextframe add-clip /tmp/t.json --track v1 --scene auroraGradient --start 0 --duration 12",
          "nextframe add-clip /tmp/t.json --track v3 --scene kineticHeadline --start {after:'clip-aurora-1', gap:0} --duration 4 --params text='HELLO'",
          "nextframe validate /tmp/t.json",
          "nextframe gantt /tmp/t.json",
          "nextframe frame /tmp/t.json 2.0 /tmp/probe.png",
          "nextframe render /tmp/t.json /tmp/out.mp4",
          "ffprobe /tmp/out.mp4"
        ],
        "assert": [
          "validate ok=true",
          "probe.png is 1920x1080 PNG",
          "out.mp4 duration ≈ 12.0",
          "out.mp4 codec = h264"
        ]
      },
      {
        "id": "sim-2",
        "name": "AI self-correction: invalid ref → describe → fix",
        "steps": [
          "nextframe new /tmp/t.json",
          "nextframe add-clip /tmp/t.json --track v1 --scene auroraGradient --start {at:'marker-nonexistent'}",
          "nextframe validate /tmp/t.json"
        ],
        "assert": [
          "validate ok=false",
          "errors[0].gate = 'symbolic-resolve'",
          "errors[0].hint contains 'available markers'"
        ]
      }
    ]
  }
}
