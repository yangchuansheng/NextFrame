{
  "module": "cli-render",
  "version": "v0.1",
  "description": "AI verification stories — AI operates the CLI, checks stdout/stderr/files/ffprobe, decides pass/fail.",
  "stories": [
    {
      "id": "verify-cli-render-1",
      "ref": "cli-render-1",
      "name": "happy path render",
      "steps": [
        {"op": "run", "cmd": "node bin/nextframe.js render examples/demo.timeline.json /tmp/v1.mp4", "capture": "stdout"},
        {"op": "assert_json", "path": "stdout", "expect": {"ok": true}},
        {"op": "run", "cmd": "test -f /tmp/v1.mp4 && echo ok"},
        {"op": "run", "cmd": "ffprobe -v error -show_entries format=duration,size -of json /tmp/v1.mp4", "capture": "stdout"},
        {"op": "assert_gte", "path": "stdout.format.duration", "value": 11.8},
        {"op": "assert_lte", "path": "stdout.format.duration", "value": 12.2},
        {"op": "assert_gte", "path": "stdout.format.size", "value": 100000}
      ]
    },
    {
      "id": "verify-cli-render-2",
      "ref": "cli-render-2",
      "name": "single frame png",
      "steps": [
        {"op": "run", "cmd": "node bin/nextframe.js frame examples/demo.timeline.json 5.0 /tmp/v2.png"},
        {"op": "run", "cmd": "file /tmp/v2.png", "capture": "stdout"},
        {"op": "assert_contains", "path": "stdout", "value": "1920 x 1080"},
        {"op": "screenshot_review", "path": "/tmp/v2.png", "check": "not blank, not single color, has aurora gradient visible"}
      ]
    },
    {
      "id": "verify-cli-render-3",
      "ref": "cli-render-3",
      "name": "validate rejects bad ref",
      "steps": [
        {"op": "write_file", "path": "/tmp/bad.json", "content": "{\"schema\":\"nextframe/v0.1\",\"duration\":5,\"tracks\":[{\"id\":\"v1\",\"clips\":[{\"id\":\"c1\",\"scene\":\"auroraGradient\",\"start\":{\"at\":\"marker-missing\"},\"duration\":5}]}]}"},
        {"op": "run", "cmd": "node bin/nextframe.js validate /tmp/bad.json", "expect_exit": 1, "capture": "stdout"},
        {"op": "assert_json", "path": "stdout", "expect": {"ok": false}},
        {"op": "assert_contains", "path": "stdout.errors[0].gate", "value": "symbolic"}
      ]
    },
    {
      "id": "verify-cli-render-4",
      "ref": "cli-render-4",
      "name": "describe returns structured metadata",
      "steps": [
        {"op": "run", "cmd": "node bin/nextframe.js describe examples/demo.timeline.json 5.0", "capture": "stdout"},
        {"op": "assert_has", "path": "stdout", "field": "visible_clips"},
        {"op": "assert_gte", "path": "stdout.visible_clips.length", "value": 1}
      ]
    },
    {
      "id": "verify-cli-render-5",
      "ref": "cli-render-5",
      "name": "gantt chart readable",
      "steps": [
        {"op": "run", "cmd": "node bin/nextframe.js gantt examples/demo.timeline.json", "capture": "stdout"},
        {"op": "assert_contains", "path": "stdout", "value": "v1"},
        {"op": "assert_contains", "path": "stdout", "value": "0:00"}
      ]
    }
  ],
  "tool_operations": {
    "run": "execute shell command, capture stdout/stderr/exit",
    "assert_json": "parse captured output as JSON, deep-match expected",
    "assert_gte/lte/contains": "numeric/string assertion on a JSONPath",
    "screenshot_review": "AI opens PNG file and writes natural-language judgement"
  }
}
