{
  "module": "cli-timeline-ops",
  "version": "v0.1",
  "stories": [
    {
      "id": "verify-ops-1",
      "ref": "cli-ops-1",
      "name": "new creates valid empty timeline",
      "steps": [
        {"op": "run", "cmd": "rm -f /tmp/new.json && node bin/nextframe.js new /tmp/new.json --duration 10"},
        {"op": "run", "cmd": "cat /tmp/new.json", "capture": "stdout"},
        {"op": "assert_json", "path": "stdout", "expect": {"schema": "nextframe/v0.1", "duration": 10, "tracks": []}},
        {"op": "run", "cmd": "node bin/nextframe.js validate /tmp/new.json"},
        {"op": "assert_exit", "value": 0}
      ]
    },
    {
      "id": "verify-ops-2",
      "ref": "cli-ops-2",
      "name": "add-clip produces stable id",
      "steps": [
        {"op": "run", "cmd": "node bin/nextframe.js new /tmp/t.json"},
        {"op": "run", "cmd": "node bin/nextframe.js add-clip /tmp/t.json --track v1 --scene auroraGradient --start 0 --duration 5", "capture": "stdout"},
        {"op": "assert_json", "path": "stdout", "expect": {"ok": true, "clip_id": "clip-auroraGradient-1"}},
        {"op": "run", "cmd": "node bin/nextframe.js add-clip /tmp/t.json --track v1 --scene auroraGradient --start 5 --duration 5", "capture": "stdout"},
        {"op": "assert_json", "path": "stdout", "expect": {"clip_id": "clip-auroraGradient-2"}}
      ]
    },
    {
      "id": "verify-ops-3",
      "ref": "cli-ops-3",
      "name": "symbolic time survives round trip",
      "steps": [
        {"op": "run", "cmd": "node bin/nextframe.js add-clip /tmp/t.json --track v2 --scene kineticHeadline --start '{\"after\":\"clip-auroraGradient-1\",\"gap\":1}' --duration 3"},
        {"op": "run", "cmd": "cat /tmp/t.json | jq '.tracks[1].clips[0].start'", "capture": "stdout"},
        {"op": "assert_contains", "path": "stdout", "value": "after"}
      ]
    },
    {
      "id": "verify-ops-4",
      "ref": "cli-ops-4",
      "name": "move-clip rejects out of bounds",
      "steps": [
        {"op": "run", "cmd": "node bin/nextframe.js move-clip /tmp/t.json clip-kineticHeadline-1 --to 50", "expect_exit": 1, "capture": "stdout"},
        {"op": "assert_json", "path": "stdout", "expect": {"ok": false}},
        {"op": "assert_contains", "path": "stdout.error", "value": "bound"}
      ]
    },
    {
      "id": "verify-ops-5",
      "ref": "cli-ops-7",
      "name": "set-param validates type",
      "steps": [
        {"op": "run", "cmd": "node bin/nextframe.js set-param /tmp/t.json clip-kineticHeadline-1 --text 'HELLO'", "expect_exit": 0},
        {"op": "run", "cmd": "node bin/nextframe.js set-param /tmp/t.json clip-kineticHeadline-1 --size big", "expect_exit": 1, "capture": "stdout"},
        {"op": "assert_contains", "path": "stdout.error", "value": "number"}
      ]
    }
  ]
}
