{
  "name": "杂志",
  "description": "暖色纸张底 + 金色装饰 + 首行缩进 + 书摘引用，适合深度文章、内参、专栏",
  "colors": {
    "bg": "#f8f4ed",
    "text": "#5a4e3c",
    "title": "#2c2417",
    "accent": "#c4b08a",
    "muted": "#8a7a62",
    "light": "#b8a88a",
    "card_bg": "#efe8db",
    "quote_border": "#d4c4a8"
  },
  "styles": {
    "wrapper": {
      "background_color": "#f8f4ed",
      "padding": "24px 16px",
      "margin": "-16px",
      "border_radius": "0"
    },
    "header_label": {
      "font_size": "10px",
      "color": "#b8a88a",
      "letter_spacing": "8px",
      "margin": "0 0 20px",
      "font_weight": "500",
      "text_align": "center"
    },
    "header_rule": {
      "width": "40px",
      "height": "1px",
      "background": "#c4b08a",
      "margin": "0 auto 20px"
    },
    "h1": {
      "font_size": "26px",
      "font_weight": "900",
      "color": "#2c2417",
      "line_height": "1.5",
      "margin": "0 0 10px",
      "letter_spacing": "1px",
      "text_align": "center"
    },
    "byline": {
      "font_size": "12px",
      "color": "#a0917a",
      "margin": "0",
      "letter_spacing": "2px",
      "text_align": "center"
    },
    "divider_diamond": {
      "font_size": "11px",
      "color": "#b8a88a",
      "letter_spacing": "3px"
    },
    "divider_line": {
      "height": "1px",
      "background_from": "rgba(196,176,138,0)",
      "background_to": "#c4b08a"
    },
    "p": {
      "font_size": "15px",
      "color": "#5a4e3c",
      "line_height": "2.0",
      "letter_spacing": "0.8px",
      "margin": "0 0 8px",
      "text_indent": "2em"
    },
    "strong": {
      "font_weight": "700",
      "color": "#2c2417",
      "border_bottom": "2px solid #c4b08a"
    },
    "em": {
      "font_style": "italic",
      "color": "#8a7a62"
    },
    "chapter_label": {
      "font_size": "11px",
      "color": "#b8a88a",
      "letter_spacing": "4px",
      "margin": "0 0 6px"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "800",
      "color": "#2c2417",
      "margin": "0",
      "letter_spacing": "0.5px"
    },
    "h2_underline": {
      "width": "32px",
      "height": "2px",
      "background": "#c4b08a",
      "margin": "10px 0 0"
    },
    "h3": {
      "font_size": "17px",
      "font_weight": "700",
      "color": "#2c2417",
      "margin": "0 0 4px",
      "letter_spacing": "1px"
    },
    "blockquote": {
      "border_top": "1px solid #d4c4a8",
      "border_bottom": "1px solid #d4c4a8",
      "padding": "16px 20px",
      "margin": "18px 0"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#8a7a62",
      "line_height": "1.8",
      "margin": "0",
      "font_style": "italic",
      "text_align": "center"
    },
    "list_container": {
      "padding_left": "18px",
      "border_left": "2px solid #d4c4a8",
      "margin": "18px 0"
    },
    "list_item_title": {
      "font_size": "13px",
      "font_weight": "700",
      "color": "#2c2417",
      "margin": "0 0 4px",
      "letter_spacing": "1px"
    },
    "list_item_text": {
      "font_size": "13px",
      "color": "#8a7a62",
      "line_height": "1.7",
      "margin": "0"
    },
    "pullquote": {
      "font_size": "22px",
      "font_weight": "900",
      "color": "#2c2417",
      "line_height": "1.6",
      "letter_spacing": "2px",
      "text_align": "center"
    },
    "pullquote_rule": {
      "width": "24px",
      "height": "2px",
      "background": "#c4b08a",
      "margin": "0 auto"
    },
    "metric_card": {
      "background": "#efe8db",
      "border_radius": "8px",
      "padding": "20px"
    },
    "metric_number": {
      "font_size": "28px",
      "font_weight": "900",
      "color": "#2c2417",
      "margin": "0 0 4px"
    },
    "metric_label": {
      "font_size": "11px",
      "color": "#8a7a62",
      "margin": "0",
      "letter_spacing": "2px"
    },
    "metric_divider": {
      "width": "1px",
      "background": "#d4c4a8"
    },
    "footer_label": {
      "font_size": "12px",
      "color": "#b8a88a",
      "line_height": "2.0",
      "margin": "0",
      "letter_spacing": "2px",
      "text_align": "center"
    },
    "footer_sub": {
      "font_size": "11px",
      "color": "#c4b8a0",
      "line_height": "2.0",
      "margin": "0",
      "letter_spacing": "1px",
      "text_align": "center"
    }
  }
}
