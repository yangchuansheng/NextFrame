    {
      "id": "formula-code",
      "scene": "codeBlock",
      "start": 6,
      "dur": 7,
      "params": {
        "code": "// 连续傅里叶变换 (Continuous Fourier Transform)\n// F(ω) = ∫₋∞^+∞  f(t) · e^(-iωt)  dt\n\n// 离散傅里叶变换 (DFT) — 计算机中实际使用的形式\n// X[k] = Σ_{n=0}^{N-1}  x[n] · e^(-i·2π·k·n/N)\n\n// 快速傅里叶变换 (FFT) — O(N log N) 的高效算法\nfunction fft(signal) {\n  const N = signal.length;\n  if (N <= 1) return signal;\n  const even = fft(signal.filter((_, i) => i % 2 === 0));\n  const odd  = fft(signal.filter((_, i) => i % 2 === 1));\n  return Array.from({ length: N }, (_, k) => {\n    const angle = -2 * Math.PI * k / N;\n    const w = { re: Math.cos(angle), im: Math.sin(angle) };\n    // 蝶形运算: X[k] = Even[k] + W·Odd[k]\n    return complexAdd(even[k % (N/2)], complexMul(w, odd[k % (N/2)]));\n  });\n}",
        "language": "javascript",
        "fontSize": 18,
        "theme": "dark"
      },
      "enter": "fadeIn 0.8s",
      "exit": "fadeOut 0.6s"
    },
