      "enter": "fadeIn 0.5s",
      "exit": "fadeOut 0.5s",
      "transition": "dissolve 0.6s"
    },
    {
      "id": "counter-main",
      "scene": "numberCounter",
      "start": 3.5,
      "dur": 5,
      "params": {
        "value": 10,
        "prefix": "",
        "suffix": "x Faster",
        "label": "Performance Breakthrough",
        "color": "#6ee7ff"
      },
      "enter": "scaleIn 0.8s",
      "exit": "fadeOut 0.5s",
      "transition": "dissolve 0.5s"
    },
    {
      "id": "confetti-counter",
      "scene": "confetti",
