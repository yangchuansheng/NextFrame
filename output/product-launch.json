        "progress": 99.9,
        "color": "#f472b6",
        "bgColor": "rgba(244,114,182,0.1)",
        "strokeWidth": 24,
        "label": "Uptime",
        "showPercent": true
      },
      "enter": "scaleIn 0.8s",
      "exit": "fadeOut 0.5s",
      "x": 1100,
      "w": 600
    },

    {
      "id": "code-bg",
      "scene": "shaderGradient",
      "start": 14,
      "dur": 7,
      "params": { "color1": "#000818", "color2": "#001230", "color3": "#000a20", "speed": 0.2 },
      "opacity": 0.9,
      "enter": "fadeIn 0.6s",
      "exit": "fadeOut 0.5s",
      "transition": "wipeRight 0.6s"
    },
    {
      "id": "code-block-main",
      "scene": "codeBlock",
      "start": 14.5,
      "dur": 5.5,
      "params": {
        "language": "rust",
        "code": "use nova::prelude::*;\n\n#[nova::model]\nasync fn infer(input: Tensor) -> Result<Output> {\n    let engine = NovaEngine::new()\n        .with_precision(Precision::BF16)\n        .with_batch_size(32)\n        .build()?;\n\n    engine.run(input).await\n}",
        "theme": "dark",
        "fontSize": 22,
        "showLineNumbers": true
      },
      "enter": "slideLeft 0.7s",
      "exit": "fadeOut 0.5s",
      "transition": "wipeRight 0.6s"
    },
    {
      "id": "glitch-overlay",
      "scene": "shaderGlitch",
      "start": 15,
      "dur": 5,
      "params": { "intensity": 0.3, "blockSize": 12, "colorSplit": 0.015, "scanlines": true },
      "opacity": 0.4,
      "blend": "screen",
      "enter": "fadeIn 0.5s",
      "exit": "fadeOut 0.5s"
    },

    {
      "id": "timeline-bg",
