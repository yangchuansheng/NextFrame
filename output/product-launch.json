{
  "width": 1920,
  "height": 1080,
  "fps": 30,
  "duration": 30,
  "background": "#05020f",
  "layers": [
    {
      "id": "bg-tunnel",
      "scene": "shaderTunnel",
      "start": 0,
      "dur": 30,
      "params": { "speed": 0.4, "rings": 10, "color": "#a78bfa", "twist": 3 },
      "opacity": 0.35,
      "blend": "screen"
    },
    {
      "id": "bg-plasma",
      "scene": "shaderPlasma",
      "start": 14,
      "dur": 8,
      "params": { "speed": 0.8, "scale": 5, "colors": 3 },
      "opacity": 0.25,
      "blend": "screen"
    },
    {
      "id": "vignette-global",
      "scene": "vignette",
      "start": 0,
      "dur": 30,
      "params": { "intensity": 0.75, "color": "#000000", "radius": 0.45 }
    },

    {
      "id": "stars-open",
      "scene": "starfield",
      "start": 0,
      "dur": 6,
      "params": { "count": 350, "speed": 0.8, "depth": 1.5, "color": "#a78bfa" },
      "enter": "fadeIn 1.2s",
      "exit": "fadeOut 0.8s"
    },
    {
      "id": "shader-gradient-open",
      "scene": "shaderGradient",
      "start": 0,
      "dur": 5,
      "params": { "color1": "#0d0020", "color2": "#0a0535", "color3": "#1a0040", "speed": 0.2 },
      "opacity": 0.7,
      "enter": "fadeIn 1.0s",
      "exit": "fadeOut 0.6s",
      "transition": "dissolve 0.8s"
    },
    {
      "id": "headline-intro",
      "scene": "headline",
      "start": 0.5,
      "dur": 4,
      "params": {
        "text": "Introducing Nova",
        "fontSize": 112,
        "color": "#ffffff",
        "fontWeight": "700",
        "align": "center",
        "gradient": "linear-gradient(135deg, #6ee7ff 0%, #a78bfa 50%, #f472b6 100%)"
      },
      "enter": "scaleIn 1.0s",
      "exit": "fadeOut 0.5s",
      "transition": "zoomIn"
    },

    {
      "id": "counter-bg",
      "scene": "shaderGradient",
